{
  "name": "@copilot-budget/data",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./msw": {
      "types": "./dist/msw/index.d.ts",
      "default": "./dist/msw/index.js"
    },
    "./pat": {
      "types": "./dist/pat/index.d.ts",
      "default": "./dist/pat/index.js"
    },
    "./api-client": {
      "types": "./dist/api-client/index.d.ts",
      "default": "./dist/api-client/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@copilot-budget/core": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "msw": "^2.14.6",
    "octokit": "^5.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
