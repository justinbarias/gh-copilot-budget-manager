{
  "name": "copilot-budget-manager",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "postinstall": "pnpm --filter @copilot-budget/desktop run rebuild:electron",
    "dev": "pnpm --filter @copilot-budget/desktop run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "e2e": "pnpm --filter @copilot-budget/desktop run e2e"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
